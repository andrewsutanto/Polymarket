# ── Telegram (required) ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ── Bot mode ─────────────────────────────────────────────────────
# paper = simulated trades, no real money
# live  = real trades via py-clob-client (requires keys below)
BOT_MODE=paper
STARTING_CAPITAL=50.0
SCAN_INTERVAL=120

# ── Polymarket API (required for live mode only) ─────────────────
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# ── Falcon intelligence API (optional) ───────────────────────────
FALCON_ENABLED=false
FALCON_API_TOKEN=
